# --- AI-агент (активен) ---
OPENROUTER_API_KEY=
OPENROUTER_MODEL=deepseek/deepseek-v4-pro

# --- Мой Склад (Remap 1.2 API) ---
MOYSKLAD_API_TOKEN=
MOYSKLAD_API_URL=https://api.moysklad.ru/api/remap/1.2
MOYSKLAD_ENABLED=false
MOYSKLAD_SYNC_LIMIT=500
MOYSKLAD_SYNC_ORDERS_LIMIT=2000
MOYSKLAD_AUTO_SYNC=true

# --- 1С (placeholder) ---
ONEC_ENABLED=false
ONEC_ODATA_URL=

# --- Мессенджеры ---
MESSENGER_ENABLED=false

# --- Green API (WhatsApp) ---
GREEN_API_ENABLED=false
GREEN_API_ID_INSTANCE=
GREEN_API_TOKEN=
GREEN_API_URL=https://api.green-api.com
GREEN_API_MEDIA_URL=https://media.green-api.com

# --- Telegram Bot API ---
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=

# --- Обогащение из мессенджеров ---
ENRICHMENT_CHAT_LIMIT=50
ENRICHMENT_BATCH_SIZE=5
ENRICHMENT_CONCURRENCY=3

# --- Хранилище: memory | postgres ---
REPOSITORY_BACKEND=memory
DATABASE_URL=

# --- Кэш загруженных Excel (Redis; пусто = in-memory fallback) ---
REDIS_URL=
CACHE_TTL_SECONDS=86400

# --- Модули CRM ---
LEADS_ENABLED=false
CAMPAIGNS_ENABLED=true
