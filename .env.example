# --- AI-агент (активен) ---
OPENROUTER_API_KEY=
OPENROUTER_MODEL=deepseek/deepseek-v4-pro

# --- Мой Склад (Remap 1.2 API) ---
MOYSKLAD_API_TOKEN=
MOYSKLAD_API_URL=https://api.moysklad.ru/api/remap/1.2
MOYSKLAD_ENABLED=false
MOYSKLAD_SYNC_LIMIT=0
MOYSKLAD_SYNC_ORDERS_LIMIT=0
MOYSKLAD_AUTO_SYNC=true

# --- 1С (placeholder) ---
ONEC_ENABLED=false
ONEC_ODATA_URL=

# --- Мессенджеры ---
MESSENGER_ENABLED=false

# --- Green API (WhatsApp) ---
GREEN_API_ENABLED=false
GREEN_API_ID_INSTANCE=
GREEN_API_TOKEN=
GREEN_API_URL=https://api.green-api.com
GREEN_API_MEDIA_URL=https://media.green-api.com

# --- Telegram Bot API ---
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=my_veresk_bot
TELEGRAM_API_TIMEOUT_SECONDS=10
TELEGRAM_SYNC_ON_ATTACH=false

# --- Обогащение из мессенджеров ---
ENRICHMENT_CHAT_LIMIT=50
ENRICHMENT_BATCH_SIZE=5
ENRICHMENT_CONCURRENCY=3
MESSENGER_LIVE_FETCH=false

# --- Rate limit / retry для внешних API ---
MOYSKLAD_POSITIONS_CONCURRENCY=2
MOYSKLAD_API_RETRY_MAX=4
MOYSKLAD_REQUEST_DELAY_MS=250
GREEN_API_CONCURRENCY=1
GREEN_API_RETRY_MAX=4

# --- Telegram Data Export (result.json; для Railway лучше .json.gz ~4 МБ) ---
TELEGRAM_EXPORT_PATH=data/telegram_export.json
TELEGRAM_EXPORT_AUTO_IMPORT=true
TELEGRAM_EXPORT_MAX_MB=50

# --- AI lazy-сегментация в фоне (WebSocket push на /clients) ---
AI_AUTO_SEGMENT=true
AI_LAZY_BATCH_SIZE=5

# --- Хранилище: memory | postgres ---
# --- Postgres (Railway PostgreSQL plugin → DATABASE_URL + DB_PERSIST_ENABLED=true) ---
REPOSITORY_BACKEND=memory
DATABASE_URL=
DB_PERSIST_ENABLED=false

# --- Кэш загруженных Excel (Redis; на Railway добавьте Redis plugin и REDIS_URL) ---
REDIS_URL=
CACHE_TTL_SECONDS=86400

# --- Модули CRM ---
LEADS_ENABLED=false
CAMPAIGNS_ENABLED=true
